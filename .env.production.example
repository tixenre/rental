# ════════════════════════════════════════════════════════════════════════════
# RAMBLA RENTAL — Variables de entorno para Railway
# ════════════════════════════════════════════════════════════════════════════
# Copia este archivo a .env en Railway Dashboard → Variables
# NO incluyas este archivo en git si tiene valores reales
# ════════════════════════════════════════════════════════════════════════════

# ── OBLIGATORIAS — Seguridad ──────────────────────────────────────────────────

# SECRET_KEY: Firma segura para cookies de sesión
# Generar una nueva con:
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# NUNCA reutilices esta clave entre ambientes
SECRET_KEY=genera-una-clave-aleatoria-unica-para-cada-ambiente

# DB_PATH: Ubicación de la base de datos SQLite
# En Railway con volumen persistente:
DB_PATH=/app/backend/data/equipos.db

# ALLOWED_ORIGINS: Dominios permitidos para CORS (separados por coma)
# En producción: NUNCA dejes "*"
# Ejemplo con múltiples dominios: "https://app.ramblarental.com,https://www.ramblarental.com"
ALLOWED_ORIGINS=https://tu-proyecto.up.railway.app

# ── GOOGLE OAUTH 2.0 (Opcional — pero recomendado) ─────────────────────────

# Crear credenciales en: https://console.cloud.google.com/
# → APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web application)

GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-tuClientSecret

# URL de callback — DEBE coincidir exactamente con Google Cloud Console
# La URL será: https://<tu-proyecto>.up.railway.app/auth/callback
REDIRECT_URI=https://tu-proyecto.up.railway.app/auth/callback

# ── AUTENTICACIÓN ──────────────────────────────────────────────────────────

# Emails autorizados para acceder al admin (separados por coma)
# Si está vacío, cualquier cuenta de Google puede entrar (peligroso)
# Ejemplo: "tu@gmail.com,otro@gmail.com"
ALLOWED_EMAILS=tu@gmail.com,otro@gmail.com

# ── DATOS DEL LOCADOR (para contratos PDF) ─────────────────────────────────
OWNER_NOMBRE=Marín Javier Santini Calarco
OWNER_CUIL=23-37389102-9
OWNER_DIRECCION=Falucho 4625, Mar del Plata
OWNER_TELEFONO=223 5909080
OWNER_EMAIL=ramblarental@gmail.com

# ── OPCIONALES — Primera inicialización ────────────────────────────────────

# Si NO hay usuarios en la BD al iniciar:
# - La app mostrará pantalla de registro
# - O puedes registrar el primer admin via Google OAuth si está configurado
# Para crear admin local sin Google OAuth:
# DEFAULT_ADMIN_EMAIL=admin@ramblarental.com
# DEFAULT_ADMIN_PASSWORD=cambiar-inmediatamente-despues-del-primer-login

# ════════════════════════════════════════════════════════════════════════════
# INSTRUCCIONES PARA RAILWAY:
# 1. Ir a Railway Dashboard → Seleccionar proyecto
# 2. Click en "Variables" (pestaña)
# 3. Click en "Add Variable"
# 4. Copiar cada línea de arriba (sin comentarios) y pegarla
# 5. Railway redeploy automáticamente cuando guardes
# ════════════════════════════════════════════════════════════════════════════
