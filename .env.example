# ── Frontend ─────────────────────────────────────────────────────────────────
# URL base del backend. En producción (Railway), dejar vacío = mismo origen.
# En Lovable preview o desarrollo local, apuntar al backend:
# VITE_API_URL=https://tu-app.railway.app
VITE_API_URL=

# ── Backend ──────────────────────────────────────────────────────────────────
# Requerida: clave aleatoria para firmar sesiones
# Generá una con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Base de datos PostgreSQL (Railway la inyecta automáticamente)
DATABASE_URL=postgresql://postgres:postgres@localhost/rambla_rental

# Google OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
REDIRECT_URI=http://localhost:8000/auth/callback

# Emails autorizados como admin (separados por coma). Si queda vacío, cualquier cuenta Google puede entrar.
ALLOWED_EMAILS=

# CORS — dejar vacío permite todos los orígenes (OK para desarrollo)
ALLOWED_ORIGINS=

# Datos del locador para PDFs de contratos
OWNER_NOMBRE=
OWNER_CUIL=
OWNER_DIRECCION=
OWNER_TELEFONO=
OWNER_EMAIL=
