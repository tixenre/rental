# ── Seguridad de sesión ───────────────────────────────────────────────────────
# String aleatorio largo, usado para firmar las cookies de sesión.
# Generá uno con: python3 -c "import secrets; print(secrets.token_hex(32))"
# OBLIGATORIO — sin esto las sesiones no funcionan.

SECRET_KEY=cambia-esto-por-un-secreto-largo-y-aleatorio

# ── Google OAuth (opcional) ───────────────────────────────────────────────────
# Creá un proyecto en https://console.cloud.google.com/
# → APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web application)
# → Authorized redirect URIs: https://tudominio.com/auth/callback
# Si no configurás esto, solo funciona el login local (email + contraseña).

GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-tuClientSecret

# ── URL de callback OAuth ─────────────────────────────────────────────────────
# Debe coincidir exactamente con lo configurado en Google Cloud Console.
# En desarrollo local: http://localhost:8000/auth/callback

REDIRECT_URI=https://tu-proyecto.up.railway.app/auth/callback

# ── Emails autorizados ────────────────────────────────────────────────────────
# Lista separada por comas. Solo estos emails pueden entrar al admin.
# Si está vacío, cualquier cuenta de Google puede entrar (peligroso en producción).

ALLOWED_EMAILS=tu@gmail.com,otro@gmail.com

# ── Backups automáticos ───────────────────────────────────────────────────────
# Prender en producción. En dev dejar comentado.
# BACKUP_ENABLED=true
# BACKUP_RETAIN_DAYS=30

# ── Sentry (error tracking en producción) ────────────────────────────────────
# Obtené el DSN en sentry.io → Project → Settings → Client Keys
# Si no está seteado, Sentry no se activa (seguro para desarrollo local).

# SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx
# VITE_SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx
