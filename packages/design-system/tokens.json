{
  "$schema": "https://design-tokens.org/format",
  "_meta": {
    "name": "Rambla Rental Design Tokens",
    "version": "1.0.0",
    "source": "tixenre/rental",
    "note": "Fuente machine-readable de tokens. El espejo CSS vive en src/styles/tokens/*.css. Si editás acá, regenerá el CSS (o viceversa) — mantené ambos en sync."
  },
  "color": {
    "brand": {
      "amber":      { "value": "#FAB428", "pantone": "1235 C", "desc": "Acento principal" },
      "amber-soft": { "value": "color-mix(in oklch, #FAB428 18%, transparent)", "desc": "Fondo tintado / focus ring" },
      "amber-hot":  { "value": "#FFCC55", "desc": "Stripe alternado amber-tape" }
    },
    "ink": {
      "ink":      { "value": "oklch(0.14 0.01 60)", "desc": "Warm near-black — texto/UI" },
      "ink-pure": { "value": "#000000", "desc": "Hero display + print" }
    },
    "surface": {
      "background":       { "value": "oklch(0.985 0.005 90)", "desc": "Bone — page bg" },
      "surface":          { "value": "oklch(0.97 0.008 85)", "desc": "Cards, panels" },
      "surface-elevated": { "value": "oklch(1 0 0)", "desc": "Inputs, modales" }
    },
    "text": {
      "foreground":       { "value": "oklch(0.18 0.01 60)" },
      "muted-foreground": { "value": "oklch(0.42 0.01 70)" }
    },
    "border": {
      "hairline": { "value": "oklch(0.18 0.01 60 / 12%)" },
      "border":   { "value": "oklch(0.18 0.01 60 / 12%)" },
      "input":    { "value": "oklch(0.18 0.01 60 / 16%)" }
    },
    "semantic": {
      "primary":              { "value": "oklch(0.18 0.01 60)" },
      "primary-foreground":   { "value": "oklch(0.985 0.005 90)" },
      "secondary":            { "value": "oklch(0.94 0.008 85)" },
      "secondary-foreground": { "value": "oklch(0.18 0.01 60)" },
      "muted":                { "value": "oklch(0.94 0.008 85)" },
      "accent":               { "value": "#FAB428" },
      "accent-foreground":    { "value": "oklch(0.18 0.01 60)" },
      "destructive":          { "value": "oklch(0.62 0.22 27)" },
      "destructive-foreground": { "value": "oklch(0.98 0.005 80)" },
      "ring":                 { "value": "color-mix(in oklch, #FAB428 60%, transparent)" }
    },
    "status": {
      "rosa":    { "value": "#ED7BAD", "pantone": "211 C",  "desc": "Devuelto" },
      "azul":    { "value": "#1097DB", "pantone": "299 C",  "desc": "Presupuesto / info" },
      "naranja": { "value": "#E9552F", "pantone": "172 C",  "desc": "Aviso" },
      "verde":   { "value": "#009971", "pantone": "7724 C", "desc": "Confirmado / éxito" }
    },
    "chart": {
      "order": ["amber", "azul", "naranja", "verde", "rosa"]
    },
    "dark": {
      "background":       { "value": "oklch(0.16 0.01 60)" },
      "foreground":       { "value": "oklch(0.97 0.008 85)" },
      "surface":          { "value": "oklch(0.2 0.01 60)" },
      "surface-elevated": { "value": "oklch(0.24 0.01 60)" },
      "hairline":         { "value": "oklch(1 0 0 / 12%)" },
      "muted-foreground": { "value": "oklch(0.72 0.01 70)" }
    }
  },
  "font": {
    "display": { "value": "Champ Black", "fallback": "TT Commons, ui-sans-serif, system-ui, sans-serif", "weights": [900], "use": "SOLO display/wordmark hero" },
    "sans":    { "value": "TT Commons", "fallback": "ui-sans-serif, system-ui, -apple-system, Segoe UI, sans-serif", "weights": [400, 500, 600, 700, 900], "use": "Todo el UI" },
    "mono":    { "value": "JetBrains Mono", "fallback": "ui-monospace, monospace", "weights": [400, 500, 600, 700], "use": "Precios, fechas, IDs, eyebrows" }
  },
  "radius": {
    "sm":  { "value": "8px" },
    "md":  { "value": "10px" },
    "lg":  { "value": "12px", "desc": "base — cards" },
    "xl":  { "value": "16px" },
    "2xl": { "value": "20px" },
    "3xl": { "value": "24px" },
    "4xl": { "value": "28px" },
    "pill": { "value": "9999px" }
  },
  "shadow": {
    "sm": { "value": "0 1px 2px oklch(0.18 0.01 60 / 6%)" },
    "md": { "value": "0 4px 12px oklch(0.18 0.01 60 / 8%), 0 1px 3px oklch(0.18 0.01 60 / 5%)" },
    "lg": { "value": "0 12px 32px oklch(0.18 0.01 60 / 10%), 0 2px 8px oklch(0.18 0.01 60 / 6%)" },
    "xl": { "value": "0 24px 56px oklch(0.18 0.01 60 / 12%), 0 6px 16px oklch(0.18 0.01 60 / 8%)" }
  },
  "duration": {
    "fast":  { "value": "120ms" },
    "base":  { "value": "200ms" },
    "slow":  { "value": "350ms" },
    "xslow": { "value": "550ms" }
  },
  "ease": {
    "default": { "value": "cubic-bezier(0.32, 0.72, 0, 1)" },
    "out":     { "value": "cubic-bezier(0, 0, 0.2, 1)" },
    "bounce":  { "value": "cubic-bezier(0.34, 1.56, 0.64, 1)" }
  },
  "zIndex": {
    "sub-toolbar":  { "value": 30 },
    "cat-bar":      { "value": 40 },
    "cart-strip":   { "value": 45 },
    "topbar-amber": { "value": 49 },
    "topbar":       { "value": 50 },
    "scrim":        { "value": 60 },
    "drawer":       { "value": 61 }
  }
}
